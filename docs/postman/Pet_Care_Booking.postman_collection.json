              "raw": "{\n  \"name\": \"Mochi\",\n  \"ageYears\": 2,\n  \"weightKg\": 4.5,\n  \"petType\": \"dog\",\n  \"vaccinationStatus\": \"vaccinated\",\n  \"imageDataUrl\": null\n}"
