PORT=5000
NODE_ENV=development
API_PREFIX=/api/v1
MONGODB_URI=mongodb://127.0.0.1:27017/pet-booking
CLIENT_URL=http://localhost:3000
ACCESS_TOKEN_SECRET=replace-with-a-strong-access-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-a-strong-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=7d
# Zalo OAuth: https://developers.zalo.me/app/{app_id}/settings
ZALO_APP_ID=2334159220396951537
ZALO_APP_SECRET=
# Must match redirect URI registered in Zalo Dashboard (Login / OAuth)
ZALO_CALLBACK_URL=
FIREBASE_SERVICE_ACCOUNT_PATH=src/firebase/serviceAccountKey.json
# Comma-separated OAuth client IDs from Firebase/Google Cloud (for Google Sign-In id tokens)
GOOGLE_OAUTH_CLIENT_IDS=674702415842-qp6pb8fg2tf0eujddj4o97mtobug60lm.apps.googleusercontent.com,674702415842-aob7322jl4932pau902kgc3tqmt3kimf.apps.googleusercontent.com
# Password reset OTP — Mailtrap sandbox: https://mailtrap.io → Email Testing → Integration
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_mailtrap_username
SMTP_PASS=your_mailtrap_password
MAIL_FROM="Pet Booking <noreply@mailtrap.io>"
OTP_EXPIRES_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
